# ----------------------------------------
# Backend Environment Variables
# ----------------------------------------

# The port the backend server will run on (Render will typically assign this automatically in production)
PORT=5000

MONGO_URI=mongodb://localhost:27017/tradingview_mcp

# Trading Engine Mode
# Set to 'false' to use the local dummy paper-trading service
# Set to 'true' in the future when you integrate a live exchange API (e.g., Binance/Bybit)
USE_LIVE_EXCHANGE=false
